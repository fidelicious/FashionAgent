# Copy this file to secrets/.env, fill in real values, then chmod 600 secrets/.env
# Never commit secrets/.env — it is in .gitignore.

# ── Discord ────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → your app → Bot
DISCORD_TOKEN=replace-me

# Your own Discord user ID. Right-click your name in Discord → Copy User ID.
# (Enable Developer Mode first: Settings → Advanced.)
# Only this user can talk to the bot. Required.
DISCORD_USER_ID=replace-me

# Your private server's guild ID. Right-click the server icon → Copy Server ID.
# Slash commands are registered to this guild for instant updates (vs ~1h global propagation).
DISCORD_GUILD_ID=replace-me

# Channel where daily outfit pushes land. Right-click the channel → Copy Channel ID.
DISCORD_CHANNEL_ID=replace-me

# ── Optional ───────────────────────────────────────────────────────────────
# Override Ollama URL (default: http://ollama:11434 inside Docker network)
# OLLAMA_BASE_URL=http://ollama:11434

# Override log level (DEBUG, INFO, WARNING, ERROR). Default INFO.
# CLAWBOT_LOG_LEVEL=INFO
